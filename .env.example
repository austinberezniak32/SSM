# Required in production (Railway sets DATABASE_URL automatically when you add Postgres)
DATABASE_URL=postgres://user:pass@host:5432/dbname

# Your Anthropic API key — powers packing slip scanning (server-side only, never sent to the phone)
ANTHROPIC_API_KEY=sk-ant-...

# Passcode required to log in to the app
APP_PASSCODE=change-me

# Secret used to sign login cookies — set to any long random string
SESSION_SECRET=change-me-to-a-long-random-string

# Port (Railway sets this automatically)
PORT=3000

# Optional — auto-forward every logged receipt to purchasing (proof of receipt
# with the slip photo attached). All five must be set to activate.
# PURCHASING_EMAIL=purchasing@yourcompany.com
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@yourcompany.com
# SMTP_PASS=an-app-password

# Optional — override the AI scan model (default claude-sonnet-4-6)
# SCAN_MODEL=claude-haiku-4-5
